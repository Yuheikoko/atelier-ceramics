---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<footer class="bg-stone-950 text-stone-400 py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 border-b border-stone-800 pb-8 mb-8">
      <a href={`/${lang}/`} class="font-serif text-2xl tracking-[0.15em] text-stone-50">
        ATELIER
      </a>
      <p class="text-xs tracking-[0.15em] uppercase text-stone-500">{tr.footer.tagline}</p>
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs">
      <p class="text-stone-600">{tr.footer.license}</p>
      <p class="text-stone-600">{tr.footer.copy}</p>
    </div>
  </div>
</footer>
