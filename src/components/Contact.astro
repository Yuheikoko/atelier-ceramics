---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const f = tr.contact.form;
---

<section id="contact" class="py-28 md:py-40 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: info -->
      <div>
        <p class="eyebrow mb-5 fade-up">{tr.contact.eyebrow}</p>
        <h2 class="font-serif text-4xl md:text-5xl text-stone-900 mb-6 leading-tight fade-up delay-1">{tr.contact.title}</h2>
        <div class="w-8 h-px bg-accent mb-8 fade-up delay-2"></div>
        <p class="text-stone-600 leading-relaxed mb-12 fade-up delay-3">{tr.contact.subtitle}</p>

        <!-- メールアドレス: JavaScriptで動的描画（スパムボット対策） -->
        <div class="fade-up delay-4">
          <p class="text-xs font-medium tracking-[0.15em] uppercase text-stone-500 mb-2">Email</p>
          <a id="contact-email" href="#" class="font-serif text-lg text-stone-900 hover:text-accent transition-colors duration-300">
            &#8203;
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="fade-up delay-2">
        <form
          id="contact-form"
          action="/contact.php"
          method="POST"
          novalidate
          class="space-y-6"
        >
          <!-- Honeypot: ボット対策（非表示） -->
          <input type="text" name="website" class="hidden" tabindex="-1" aria-hidden="true" autocomplete="off" />

          <!-- Name -->
          <div>
            <label for="name" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.name} <span class="text-accent" aria-label="required">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              aria-required="true"
              autocomplete="name"
              class="w-full border-b-2 border-stone-300 bg-stone-50/50 py-3 px-1 text-stone-900 placeholder-stone-500 text-sm focus:outline-none focus:border-accent transition-colors duration-200"
              placeholder={f.name}
            />
            <p class="error-msg hidden text-xs text-red-600 mt-1" data-field="name" role="alert">{f.required}</p>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.email} <span class="text-accent" aria-label="required">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              aria-required="true"
              autocomplete="email"
              class="w-full border-b-2 border-stone-300 bg-stone-50/50 py-3 px-1 text-stone-900 placeholder-stone-500 text-sm focus:outline-none focus:border-accent transition-colors duration-200"
              placeholder={f.email}
            />
            <p class="error-msg hidden text-xs text-red-600 mt-1" data-field="email" role="alert">{f.invalidEmail}</p>
          </div>

          <!-- Subject -->
          <div>
            <label for="subject" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.subject}
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              autocomplete="off"
              class="w-full border-b-2 border-stone-300 bg-stone-50/50 py-3 px-1 text-stone-900 placeholder-stone-500 text-sm focus:outline-none focus:border-accent transition-colors duration-200"
              placeholder={f.subject}
            />
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.message} <span class="text-accent" aria-label="required">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              aria-required="true"
              class="w-full border-b-2 border-stone-300 bg-stone-50/50 py-3 px-1 text-stone-900 placeholder-stone-500 text-sm focus:outline-none focus:border-accent transition-colors duration-200 resize-none"
              placeholder={f.message}
            ></textarea>
            <p class="error-msg hidden text-xs text-red-600 mt-1" data-field="message" role="alert">{f.required}</p>
          </div>

          <!-- Status message -->
          <p id="form-status" class="hidden text-sm" role="alert" tabindex="-1"></p>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="btn-primary w-full justify-center"
            data-submit-text={f.submit}
            data-sending-text={f.sending}
          >
            {f.submit}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ successMsg: f.success, errorMsg: f.error }}>
  // メールアドレスを動的に描画（ボット収集対策）
  const emailEl = document.getElementById('contact-email');
  if (emailEl) {
    const e = atob('dGFpc2VpOTI1bWFub0BnbWFpbC5jb20=');
    emailEl.href = `mailto:${e}`;
    emailEl.textContent = e;
  }

  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validation
    let valid = true;
    const fields = ['name', 'email', 'message'];
    fields.forEach((field) => {
      const input = form.querySelector(`[name="${field}"]`);
      const errEl = form.querySelector(`[data-field="${field}"]`);
      if (!input || !errEl) return;
      const val = input.value.trim();
      let fieldValid = val !== '';
      if (field === 'email' && fieldValid) {
        fieldValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      }
      if (!fieldValid) {
        errEl.classList.remove('hidden');
        input.setAttribute('aria-invalid', 'true');
        input.classList.add('border-red-400');
        valid = false;
      } else {
        errEl.classList.add('hidden');
        input.removeAttribute('aria-invalid');
        input.classList.remove('border-red-400');
      }
    });

    if (!valid) return;

    submitBtn.textContent = submitBtn.dataset.sendingText;
    submitBtn.disabled = true;
    status?.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        signal: AbortSignal.timeout(10000),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      status.textContent = successMsg;
      status.className = 'text-sm text-green-700 bg-green-50 border border-green-200 p-4';
      status.classList.remove('hidden');
      status.focus();
      form.reset();
    } catch (err) {
      let msg = errorMsg;
      if (err instanceof TypeError) msg = 'Network error. Please check your connection.';
      if (err.name === 'AbortError') msg = 'Request timeout. Please try again.';
      status.textContent = msg;
      status.className = 'text-sm text-red-600 bg-red-50 border border-red-200 p-4';
      status.classList.remove('hidden');
      status.focus();
    } finally {
      submitBtn.textContent = submitBtn.dataset.submitText;
      submitBtn.disabled = false;
    }
  });
</script>
