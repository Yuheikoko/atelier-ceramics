---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const f = tr.contact.form;
---

<section id="contact" class="py-28 md:py-40 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: info -->
      <div>
        <p class="eyebrow mb-5 fade-up">{tr.contact.eyebrow}</p>
        <h2 class="font-serif text-4xl md:text-5xl text-stone-900 mb-6 leading-tight fade-up delay-1">{tr.contact.title}</h2>
        <div class="w-8 h-px bg-accent mb-8 fade-up delay-2"></div>
        <p class="text-stone-600 leading-relaxed mb-12 fade-up delay-3">{tr.contact.subtitle}</p>

        <div class="fade-up delay-4">
          <p class="text-xs font-medium tracking-[0.15em] uppercase text-stone-500 mb-2">Email</p>
          <a href="mailto:taisei925mano@gmail.com" class="font-serif text-lg text-stone-900 hover:text-accent transition-colors duration-300">
            taisei925mano@gmail.com
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="fade-up delay-2">
        <form
          id="contact-form"
          action="/contact.php"
          method="POST"
          novalidate
          class="space-y-6"
        >
          <!-- Name -->
          <div>
            <label for="name" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.name} <span class="text-accent">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border-b border-stone-300 bg-transparent py-3 text-stone-900 placeholder-stone-400 text-sm focus:outline-none focus:border-stone-900 transition-colors duration-300"
              placeholder={f.name}
            />
            <p class="error-msg hidden text-xs text-red-500 mt-1" data-field="name">{f.required}</p>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.email} <span class="text-accent">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border-b border-stone-300 bg-transparent py-3 text-stone-900 placeholder-stone-400 text-sm focus:outline-none focus:border-stone-900 transition-colors duration-300"
              placeholder={f.email}
            />
            <p class="error-msg hidden text-xs text-red-500 mt-1" data-field="email">{f.invalidEmail}</p>
          </div>

          <!-- Subject -->
          <div>
            <label for="subject" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.subject}
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full border-b border-stone-300 bg-transparent py-3 text-stone-900 placeholder-stone-400 text-sm focus:outline-none focus:border-stone-900 transition-colors duration-300"
              placeholder={f.subject}
            />
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-xs font-medium tracking-[0.12em] uppercase text-stone-600 mb-2">
              {f.message} <span class="text-accent">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full border-b border-stone-300 bg-transparent py-3 text-stone-900 placeholder-stone-400 text-sm focus:outline-none focus:border-stone-900 transition-colors duration-300 resize-none"
              placeholder={f.message}
            ></textarea>
            <p class="error-msg hidden text-xs text-red-500 mt-1" data-field="message">{f.required}</p>
          </div>

          <!-- Status message -->
          <p id="form-status" class="hidden text-sm"></p>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="btn-primary w-full justify-center"
            data-submit-text={f.submit}
            data-sending-text={f.sending}
          >
            {f.submit}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ successMsg: f.success, errorMsg: f.error }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic validation
    let valid = true;
    const fields = ['name', 'email', 'message'];
    fields.forEach((field) => {
      const input = form.querySelector(`[name="${field}"]`);
      const errEl = form.querySelector(`[data-field="${field}"]`);
      if (!input || !errEl) return;
      const val = input.value.trim();
      let fieldValid = val !== '';
      if (field === 'email' && fieldValid) {
        fieldValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      }
      if (!fieldValid) {
        errEl.classList.remove('hidden');
        input.classList.add('border-red-400');
        valid = false;
      } else {
        errEl.classList.add('hidden');
        input.classList.remove('border-red-400');
      }
    });

    if (!valid) return;

    // Submit
    submitBtn.textContent = submitBtn.dataset.sendingText;
    submitBtn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        status.textContent = successMsg;
        status.className = 'text-sm text-green-700';
        status.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      status.textContent = errorMsg;
      status.className = 'text-sm text-red-600';
      status.classList.remove('hidden');
    } finally {
      submitBtn.textContent = submitBtn.dataset.submitText;
      submitBtn.disabled = false;
    }
  });
</script>
