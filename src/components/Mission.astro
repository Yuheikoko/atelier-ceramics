---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="py-28 md:py-40 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- Left: text -->
      <div>
        <p class="eyebrow mb-6 fade-up">{tr.mission.eyebrow}</p>
        <h2 class="font-serif text-4xl md:text-5xl text-stone-900 mb-8 leading-tight fade-up delay-1">
          {tr.mission.title.split('\n').map((line: string) => (
            <span class="block">{line}</span>
          ))}
        </h2>
        <div class="w-10 h-px bg-accent mb-8 fade-up delay-2"></div>
        <p class="text-stone-700 leading-relaxed mb-6 fade-up delay-3">{tr.mission.p1}</p>
        <p class="text-stone-700 leading-relaxed fade-up delay-4">{tr.mission.p2}</p>
      </div>

      <!-- Right: stats -->
      <div class="lg:pt-20">
        <div class="grid grid-cols-1 gap-0 border-t border-stone-200">
          {[tr.mission.stat1, tr.mission.stat2, tr.mission.stat3].map((stat, i) => (
            <div class={`py-8 border-b border-stone-200 fade-up delay-${i + 2}`}>
              <p class="font-serif text-4xl md:text-5xl text-stone-900 mb-2">{stat.value}</p>
              <p class="text-xs font-medium tracking-[0.15em] uppercase text-stone-500">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
