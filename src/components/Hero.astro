---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="relative min-h-screen flex items-end pb-20 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/main001.jpg"
      alt="Japanese ceramics atelier"
      class="w-full h-full object-cover"
      fetchpriority="high"
    />
    <!-- Gradient overlay: subtle, light -->
    <div class="absolute inset-0 bg-gradient-to-t from-stone-950/60 via-stone-950/20 to-transparent"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 w-full">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <p class="text-xs font-medium tracking-[0.25em] uppercase text-stone-300 mb-6 fade-up">
        {tr.hero.eyebrow}
      </p>

      <!-- Main title -->
      <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl text-stone-50 mb-8 leading-[1.05] fade-up delay-1">
        {tr.hero.title.split('\n').map((line: string) => (
          <span class="block">{line}</span>
        ))}
      </h1>

      <!-- Subtitle -->
      <p class="text-base md:text-lg text-stone-300 mb-12 max-w-xl leading-relaxed fade-up delay-2">
        {tr.hero.subtitle}
      </p>

      <!-- CTA -->
      <div class="fade-up delay-3">
        <a href={`#collections`} class="btn-primary bg-stone-50 text-stone-900 hover:bg-accent hover:text-stone-50">
          {tr.hero.cta}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 md:right-12 flex flex-col items-center gap-2 fade-up delay-5">
    <span class="text-xs tracking-[0.2em] uppercase text-stone-400 [writing-mode:vertical-rl]">Scroll</span>
    <div class="w-px h-12 bg-stone-400/50 relative overflow-hidden">
      <div class="absolute top-0 w-full h-1/2 bg-stone-300 animate-scroll-line"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  .animate-scroll-line {
    animation: scroll-line 1.8s ease-in-out infinite;
  }
</style>
