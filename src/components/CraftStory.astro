---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section id="story" class="py-28 md:py-40 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Header -->
    <div class="max-w-2xl mb-20">
      <p class="eyebrow mb-5 fade-up">{tr.story.eyebrow}</p>
      <h2 class="font-serif text-4xl md:text-6xl text-stone-900 leading-tight fade-up delay-1">
        {tr.story.title.split('\n').map((line: string) => (
          <span class="block">{line}</span>
        ))}
      </h2>
    </div>

    <!-- Seto -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-24 lg:mb-32">
      <div class="order-2 lg:order-1">
        <p class="eyebrow mb-4 fade-up">{tr.story.seto.label}</p>
        <h3 class="font-serif text-3xl md:text-4xl text-stone-900 mb-6 fade-up delay-1">{tr.story.seto.title}</h3>
        <div class="w-8 h-px bg-accent mb-6 fade-up delay-2"></div>
        <p class="text-stone-700 leading-relaxed fade-up delay-3">{tr.story.seto.body}</p>
      </div>
      <div class="order-1 lg:order-2 fade-up delay-2">
        <div class="aspect-[4/3] overflow-hidden">
          <img
            src="/images/0001.jpg"
            alt="Seto ware ceramics"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <!-- Tokoname -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="fade-up delay-1">
        <div class="aspect-[4/3] overflow-hidden">
          <img
            src="/images/0002.jpg"
            alt="Tokoname ware ceramics"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div>
        <p class="eyebrow mb-4 fade-up">{tr.story.tokoname.label}</p>
        <h3 class="font-serif text-3xl md:text-4xl text-stone-900 mb-6 fade-up delay-1">{tr.story.tokoname.title}</h3>
        <div class="w-8 h-px bg-accent mb-6 fade-up delay-2"></div>
        <p class="text-stone-700 leading-relaxed fade-up delay-3">{tr.story.tokoname.body}</p>
      </div>
    </div>
  </div>
</section>
