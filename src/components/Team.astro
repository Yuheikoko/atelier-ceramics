---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const [primary, secondary] = tr.team.members;
---

<section id="team" class="py-28 md:py-40 bg-gradient-to-b from-stone-800 to-stone-900 text-stone-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="mb-16">
      <p class="eyebrow text-accent mb-5 fade-up">{tr.team.eyebrow}</p>
      <h2 class="font-serif text-4xl md:text-5xl fade-up delay-1">{tr.team.title}</h2>
    </div>

    <!-- 眞野: 主役として大きく表示 -->
    <div class="border-t border-stone-700 mb-0">
      <div class="py-14 md:py-20 border-b border-stone-700 fade-up delay-2">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-16 items-start">
          <!-- Role + Name -->
          <div>
            <p class="text-xs font-medium tracking-[0.2em] uppercase text-accent mb-4">{primary.role}</p>
            <p class="font-serif text-4xl md:text-5xl text-stone-50 mb-2">{primary.name}</p>
            <p class="text-sm text-stone-400 tracking-wider">{primary.nameJa}</p>
          </div>
          <!-- Bio -->
          <div class="lg:col-span-2">
            <div class="w-8 h-px bg-accent mb-6"></div>
            <p class="text-stone-300 leading-relaxed text-lg">{primary.bio}</p>
          </div>
        </div>
      </div>

      <!-- 小池: サポート役としてコンパクトに -->
      <div class="py-10 border-b border-stone-700 fade-up delay-3">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-16 items-start">
          <div>
            <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500 mb-3">{secondary.role}</p>
            <p class="font-serif text-2xl text-stone-300 mb-1">{secondary.name}</p>
            <p class="text-sm text-stone-500 tracking-wider">{secondary.nameJa}</p>
          </div>
          <div class="lg:col-span-2">
            <p class="text-stone-500 leading-relaxed">{secondary.bio}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
