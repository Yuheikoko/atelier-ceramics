---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Mission from '../../components/Mission.astro';
import Collections from '../../components/Collections.astro';
import CraftStory from '../../components/CraftStory.astro';
import Team from '../../components/Team.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  lang={lang}
  title="ATELIER — Japanese Traditional Ceramics from Aichi, Japan"
  description="Discover handcrafted ceramics from Seto and Tokoname — two of Japan's most storied pottery regions — brought to the global stage."
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Mission lang={lang} />
    <Collections lang={lang} />
    <CraftStory lang={lang} />
    <Team lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
