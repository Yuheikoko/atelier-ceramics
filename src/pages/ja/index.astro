---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Mission from '../../components/Mission.astro';
import Collections from '../../components/Collections.astro';
import CraftStory from '../../components/CraftStory.astro';
import Team from '../../components/Team.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';

const lang = 'ja' as const;
---

<Layout
  lang={lang}
  title="ATELIER — 愛知の伝統陶芸を世界へ｜瀬戸焼・常滑焼"
  description="愛知県を代表する陶芸産地、瀬戸と常滑。その匠の技が生み出す器を、世界の舞台へと届けます。"
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Mission lang={lang} />
    <Collections lang={lang} />
    <CraftStory lang={lang} />
    <Team lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
